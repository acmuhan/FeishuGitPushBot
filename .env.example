# 飞书机器人配置
# 可选：如果需要更新已发送的消息、回复评论（话题模式），则需要以下配置
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_CHAT_ID=xxxx

# GitHub 配置
GITHUB_KEY=xxxx
GITHUB_BOT_USERS=user1,user2

# 数据库配置 (可选：用于存储消息记录以便后续更新或回复)
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# 事件合并窗口（分钟），默认 15
EVENTS_MERGE_WINDOW=15

# 话题回复窗口（分钟），超过此时间的父消息不再以话题回复，而是发送到群组，默认 60
EVENTS_THREAD_REPLY_WINDOW=60

# GitHub Webhook 来源 IP 白名单（CIDR，逗号分隔），留空则不校验
GITHUB_WEBHOOK_IPS=
